# AI classification is optional. If disabled, the app uses deterministic rules only.
AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Digest sender settings. Use a separate sender; scanned Gmail accounts stay read-only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
